# 1. Pin the exact Python version to prevent unexpected breaking changes
FROM public.ecr.aws/lambda/python:3.12

# 2. Set the working directory (AWS default is /var/task)
WORKDIR ${LAMBDA_TASK_ROOT}

# 3. Copy requirements first to leverage Docker layer caching
COPY requirements.txt .

# 4. Install dependencies explicitly into the Task Root
RUN pip install -r requirements.txt --target "${LAMBDA_TASK_ROOT}"

# 5. Copy ALL your application code into the container (not just the handler)
COPY . ${LAMBDA_TASK_ROOT}

# 6. Set the CMD to your handler (filename.function_name)
CMD ["lambda_function.lambda_handler"]